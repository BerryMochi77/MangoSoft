<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Required so AiPostCurationStrategy can reach api.deepseek.com over HTTPS. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".SocialModerationApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.COMP2100Miniproject">
        <activity
            android:name=".AvatarCropActivity"
            android:exported="false" />
        <activity
            android:name=".CreatePostActivity"
            android:exported="false" />
        <activity
            android:name=".AdminAnalyticsDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".AdminAiAnalyticsActivity"
            android:exported="false" />
        <activity
            android:name=".AdminUserListActivity"
            android:exported="false" />
        <activity
            android:name=".AdminPostListActivity"
            android:exported="false" />
        <activity
            android:name=".AdminReplyListActivity"
            android:exported="false" />
        <activity
            android:name=".AdminPostReportsActivity"
            android:exported="false" />
        <activity
            android:name=".FrozenUsersActivity"
            android:exported="true" />
        <activity
            android:name=".AdminReportsActivity"
            android:exported="true" />
        <activity
            android:name=".PostViewerActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize|stateHidden" />
        <activity
            android:name=".UserProfileActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true" />
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
