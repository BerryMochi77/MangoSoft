<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card"
    android:padding="14dp">

    <com.example.comp2100miniproject.CircleAvatarImageView
        android:id="@+id/imageMessageAvatar"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:contentDescription="@string/profile_avatar"
        android:src="@drawable/avatar_default_1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textMessageAuthor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/buttonReportMessage"
        app:layout_constraintStart_toEndOf="@+id/imageMessageAvatar"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textMessageTimestamp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@+id/buttonReportMessage"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/textMessageAuthor" />

    <ImageButton
        android:id="@+id/buttonReportMessage"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/report"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_report_flag"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/warning" />

    <TextView
        android:id="@+id/textMessageContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/textMessageTimestamp" />

    <LinearLayout
        android:id="@+id/messageOwnerActions"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:gravity="end"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textMessageContent">

        <Button
            android:id="@+id/buttonEditMessage"
            android:layout_width="82dp"
            android:layout_height="34dp"
            android:text="@string/edit"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/buttonDeleteMessage"
            android:layout_width="82dp"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:text="@string/delete"
            android:textAllCaps="false"
            android:textSize="12sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
