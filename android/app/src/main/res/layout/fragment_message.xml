<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!--
        Comment row.
          • threadIndent draws the indent rail on the left (depth set by adapter).
          • Top-right has a single ⋮ overflow button. Tapping it opens a
            PopupMenu wired in MessageAdapter -> PostViewerActivity:
            Save / Unsave, Report, Edit (own only), Delete (own only).
          • Bottom-right has the primary actions: 👍 count 👎 count 💬.
            All three are visible to every viewer.
          • Counts come from MessageReactionRegistry, bookmark state from
            MessageBookmarkRegistry — both sidecars under
            messagestate/ so Message itself stays untouched.
    -->

    <com.example.comp2100miniproject.ThreadIndentView
        android:id="@+id/threadIndent"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.example.comp2100miniproject.CircleAvatarImageView
        android:id="@+id/imageMessageAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:contentDescription="@string/profile_avatar"
        android:src="@drawable/avatar_default_1"
        app:layout_constraintStart_toEndOf="@+id/threadIndent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textMessageAuthor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="4dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/buttonMessageOverflow"
        app:layout_constraintStart_toEndOf="@+id/imageMessageAvatar"
        app:layout_constraintTop_toTopOf="@+id/imageMessageAvatar" />

    <TextView
        android:id="@+id/textMessageTimestamp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@+id/imageMessageAvatar"
        app:layout_constraintEnd_toStartOf="@+id/buttonMessageOverflow"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor" />

    <ImageButton
        android:id="@+id/buttonMessageOverflow"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/message_options"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_more_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_secondary" />

    <TextView
        android:id="@+id/textMessageContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="14dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/textMessageTimestamp" />

    <com.example.comp2100miniproject.RoundedImageView
        android:id="@+id/imageMessageAttachment"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:adjustViewBounds="true"
        android:background="@drawable/bg_card"
        android:contentDescription="@string/attached_image"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/textMessageContent" />

    <LinearLayout
        android:id="@+id/messageActionRow"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageMessageAttachment">

        <ImageButton
            android:id="@+id/buttonLikeMessage"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/like"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_thumb_up"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/textLikeCount"
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="6dp"
            android:gravity="center_vertical|start"
            android:includeFontPadding="false"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/buttonDislikeMessage"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/dislike"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_thumb_down"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/textDislikeCount"
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="6dp"
            android:gravity="center_vertical|start"
            android:includeFontPadding="false"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/buttonCommentMessage"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/comment_on"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_comment"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <View
        android:id="@+id/messageDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:background="@color/border"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/messageActionRow" />
</androidx.constraintlayout.widget.ConstraintLayout>
