<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!--
        Reddit-style thread row: vertical "thread lines" on the left whose
        count == nesting depth (set by MessageAdapter via
        ThreadIndentView.setDepth). No card background; comments separate
        from one another via a thin bottom divider instead.
    -->

    <com.example.comp2100miniproject.ThreadIndentView
        android:id="@+id/threadIndent"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.example.comp2100miniproject.CircleAvatarImageView
        android:id="@+id/imageMessageAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:contentDescription="@string/profile_avatar"
        android:src="@drawable/avatar_default_1"
        app:layout_constraintStart_toEndOf="@+id/threadIndent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textMessageAuthor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="4dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/buttonReplyMessage"
        app:layout_constraintStart_toEndOf="@+id/imageMessageAvatar"
        app:layout_constraintTop_toTopOf="@+id/imageMessageAvatar" />

    <TextView
        android:id="@+id/textMessageTimestamp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@+id/imageMessageAvatar"
        app:layout_constraintEnd_toStartOf="@+id/buttonReplyMessage"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor" />

    <ImageButton
        android:id="@+id/buttonReplyMessage"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/reply"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_reply"
        app:layout_constraintEnd_toStartOf="@+id/buttonReportMessage"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_secondary" />

    <ImageButton
        android:id="@+id/buttonReportMessage"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/report"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_report_flag"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/warning" />

    <TextView
        android:id="@+id/textMessageContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="14dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/textMessageTimestamp" />

    <LinearLayout
        android:id="@+id/messageOwnerActions"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="14dp"
        android:gravity="end"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/textMessageContent">

        <Button
            android:id="@+id/buttonEditMessage"
            android:layout_width="72dp"
            android:layout_height="30dp"
            android:minHeight="0dp"
            android:text="@string/edit"
            android:textAllCaps="false"
            android:textSize="11sp" />

        <Button
            android:id="@+id/buttonDeleteMessage"
            android:layout_width="72dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:minHeight="0dp"
            android:text="@string/delete"
            android:textAllCaps="false"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:id="@+id/messageDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="14dp"
        android:background="@color/border"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMessageAuthor"
        app:layout_constraintTop_toBottomOf="@+id/messageOwnerActions" />
</androidx.constraintlayout.widget.ConstraintLayout>
