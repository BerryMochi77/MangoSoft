<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card"
    android:minHeight="76dp"
    android:padding="14dp">

    <com.example.comp2100miniproject.CircleAvatarImageView
        android:id="@+id/imagePostAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:contentDescription="@string/profile_avatar"
        android:src="@drawable/avatar_default_1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textPostItemTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/textPostItemArrow"
        app:layout_constraintStart_toEndOf="@+id/imagePostAvatar"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textPostItemMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toStartOf="@+id/textPostItemArrow"
        app:layout_constraintStart_toStartOf="@+id/textPostItemTitle"
        app:layout_constraintTop_toBottomOf="@+id/textPostItemTitle" />

    <TextView
        android:id="@+id/textPostEdited"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/edited_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@+id/textPostItemTitle"
        app:layout_constraintTop_toBottomOf="@+id/textPostItemMeta" />

    <TextView
        android:id="@+id/textPostItemStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@+id/textPostItemArrow"
        app:layout_constraintStart_toStartOf="@+id/textPostItemTitle"
        app:layout_constraintTop_toBottomOf="@+id/textPostEdited" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupHashtags"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:chipSpacingHorizontal="4dp"
        app:chipSpacingVertical="2dp"
        app:layout_constraintEnd_toStartOf="@+id/textPostItemArrow"
        app:layout_constraintStart_toStartOf="@+id/textPostItemTitle"
        app:layout_constraintTop_toBottomOf="@+id/textPostItemStats" />

    <TextView
        android:id="@+id/textPostItemBody"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@+id/textPostItemArrow"
        app:layout_constraintStart_toStartOf="@+id/textPostItemTitle"
        app:layout_constraintTop_toBottomOf="@+id/chipGroupHashtags" />

    <com.example.comp2100miniproject.RoundedImageView
        android:id="@+id/imagePostItemAttachment"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:background="@drawable/bg_card"
        android:contentDescription="@string/attached_image"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@+id/textPostItemArrow"
        app:layout_constraintStart_toStartOf="@+id/textPostItemTitle"
        app:layout_constraintTop_toBottomOf="@+id/textPostItemBody" />

    <TextView
        android:id="@+id/textPostItemArrow"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:gravity="center"
        android:text=">"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
